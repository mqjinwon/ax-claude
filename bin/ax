#!/usr/bin/env bash
# ax — Personal Agent Control Plane CLI
# Commands: init, help

set -euo pipefail

resolve_script_path() {
  local source_path="$1"
  local source_dir
  if [[ "$source_path" != */* ]]; then
    source_path="$(command -v "$source_path" 2>/dev/null || printf '%s\n' "$source_path")"
  fi
  while [ -L "$source_path" ]; do
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done
  source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
  printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

# Resolve plugin root regardless of install location without GNU-specific path tools.
PLUGIN_ROOT="$(cd "$(dirname "$(resolve_script_path "${BASH_SOURCE[0]}")")/.." && pwd)"

COMMAND="${1:-help}"

case "$COMMAND" in
  init)
    # Dependency check
    command -v jq >/dev/null 2>&1 || {
      echo "ERROR: jq is required. Install with: sudo apt install jq" >&2; exit 1
    }

    PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    AX_DIR="$PROJECT_ROOT/.ax"
    MEMORY_DIR="$AX_DIR/memory"

    if [ -f "$AX_DIR/config.yaml" ]; then
      echo "ax: already initialized at $AX_DIR"
      exit 0
    fi

    mkdir -p "$MEMORY_DIR"

    SLUG=$(basename "$PROJECT_ROOT")

    # Write config (no yq dependency — plain text)
    cat > "$AX_DIR/config.yaml" << EOF
project_slug: ${SLUG}

# Rate limit auto-resume thresholds (percentage 0-100)
warn_at: 80
pause_at: 90
block_at: 100
auto_resume: true
EOF

    # Initialize MEMORY.md from template
    TEMPLATE="$PLUGIN_ROOT/templates/MEMORY.template.md"
    if [ ! -f "$TEMPLATE" ]; then
      echo "ERROR: template not found at $TEMPLATE" >&2; exit 1
    fi
    SLUG_ESCAPED=$(printf '%s' "$SLUG" | sed 's/[|&\]/\\&/g')
    sed "s|{{project_slug}}|$SLUG_ESCAPED|g" "$TEMPLATE" > "$MEMORY_DIR/MEMORY.md"

    echo "ax: initialized ✓"
    echo "  Project : $SLUG"
    echo "  Root    : $PROJECT_ROOT"
    echo "  Memory  : $MEMORY_DIR/MEMORY.md"
    echo ""
    echo "  Hooks   : SessionEnd hook is handled by the plugin system or /ax-setup"
    echo "  Use     : /ax inside Claude Code to interact with project memory"
    ;;

  queue)
    PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    AX_DIR="$PROJECT_ROOT/.ax"
    if [ ! -d "$AX_DIR" ]; then
      echo "ax: project not initialized. Run 'ax init' first." >&2
      exit 1
    fi
    TASK="${2:-}"
    if [ -z "$TASK" ]; then
      echo "Usage: ax queue \"<task description>\"" >&2
      exit 1
    fi
    printf '%s' "$TASK" > "$AX_DIR/resume-task.txt"
    echo "ax: task registered → $AX_DIR/resume-task.txt"
    echo "  Task: $TASK"
    echo "  Auto-resume will trigger if usage limit is hit."
    ;;

  help|--help|-h|*)
    cat << 'EOF'
ax — Personal Agent Control Plane

Commands:
  ax init             Initialize .ax/ for the current git project
  ax queue "<task>"   Pre-register a task for auto-resume on rate limit

Session memory is managed automatically via Claude hooks.
Use /ax inside Claude Code to interact with project memory.
EOF
    ;;
esac
