#!/usr/bin/env bash
# AX Plugin — install / reinstall
# Usage: ~/.ax/setup
#        or from fresh clone: ./setup

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION=$(tr -d '[:space:]' < "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "unknown")

echo "AX v${VERSION} — installing..."

# ── Dependency check ─────────────────────────────────────────────────────────
if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq is required." >&2
  echo "       Install: sudo apt install jq   (Debian/Ubuntu)" >&2
  echo "                brew install jq       (macOS)" >&2
  exit 1
fi

# ── python3 + pyyaml (optional — /ax routing) ────────────────────────────────
if command -v python3 >/dev/null 2>&1; then
  if python3 -c "import yaml" 2>/dev/null; then
    echo "  pyyaml  : OK"
  else
    echo "  pyyaml  : installing..."
    pip3 install pyyaml --quiet 2>/dev/null \
      || python3 -m pip install pyyaml --quiet 2>/dev/null \
      || echo "  pyyaml  : install failed — /ax routing falls back to manual match"
  fi
else
  echo "  python3 : not found — /ax routing falls back to manual match"
fi

# ── Make all scripts executable ──────────────────────────────────────────────
find "$SCRIPT_DIR" -name "*.sh" -exec chmod +x {} \;
chmod +x "$SCRIPT_DIR/bin/ax" 2>/dev/null || true

# ── PATH hint ────────────────────────────────────────────────────────────────
echo ""
echo "AX v${VERSION} installed."
echo ""
echo "  Skill and SessionEnd hook are managed by the Claude plugin system."
echo "  If installing manually (git clone), run /ax-setup in Claude Code."
echo ""
echo "  Add to PATH (add to ~/.bashrc or ~/.zshrc):"
echo "    export PATH=\"$SCRIPT_DIR/bin:\$PATH\""
echo ""
echo "  Initialize a project:"
echo "    ax init"
