#!/usr/bin/env bash
# AX Plugin — uninstall
# For plugin installs: use /plugin uninstall ax-claude in Claude Code.
# This script handles legacy (git clone) uninstall only.

set -euo pipefail

echo "AX — uninstalling (legacy mode)..."
echo ""
echo "  Note: If installed via plugin marketplace, use:"
echo "        /plugin uninstall ax-claude"
echo "        This removes skills, hooks, and the plugin cache automatically."
echo ""

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Remove skill symlink (legacy only) ───────────────────────────────────────
SKILL_LINK="$HOME/.claude/skills/ax/SKILL.md"
if [ -L "$SKILL_LINK" ]; then
  rm "$SKILL_LINK"
  echo "  Skill   : removed $SKILL_LINK"
  rmdir "$HOME/.claude/skills/ax" 2>/dev/null && echo "  Dir     : removed ~/.claude/skills/ax/" || true
else
  echo "  Skill   : not found (skipped)"
fi

# ── Remove SessionEnd hook (legacy only) ─────────────────────────────────────
SETTINGS="$HOME/.claude/settings.json"
HOOK_CMD="$SCRIPT_DIR/adapters/ax-ingest.sh"

if [ -f "$SETTINGS" ] && command -v jq >/dev/null 2>&1; then
  PRESENT=$(jq -r --arg cmd "$HOOK_CMD" '
    .hooks.SessionEnd[]?.hooks[]? |
    select(.command == $cmd) |
    .command
  ' "$SETTINGS" 2>/dev/null || true)

  if [ -n "$PRESENT" ]; then
    TMP=$(mktemp)
    trap 'rm -f "$TMP"' EXIT
    jq --arg cmd "$HOOK_CMD" '
      .hooks.SessionEnd[0].hooks |= map(select(.command != $cmd))
    ' "$SETTINGS" > "$TMP" && mv "$TMP" "$SETTINGS"
    echo "  Hook    : removed from $SETTINGS"
  else
    echo "  Hook    : not found in $SETTINGS (skipped)"
  fi
else
  echo "  Hook    : skipped (jq unavailable or settings not found)"
fi

echo ""
echo "AX uninstalled."
echo "Your project .ax/ data directories are preserved."
echo "To remove all data: find . -type d -name '.ax' -exec rm -rf {} +"
