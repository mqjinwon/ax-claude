{
  "description": "AX session memory ingestion on session end; write-guard + rate-limit on PreToolUse; auto-resume on Stop; auto skill routing on UserPromptSubmit",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/ax-auto-route.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/adapters/ax-ingest.sh",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/ax-write-guard.sh",
            "timeout": 8
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/adapters/ax-resume-watcher.sh --trigger",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
