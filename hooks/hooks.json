{
  "description": "AX session memory ingestion on session end",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/adapters/ax-ingest.sh",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ]
  }
}
